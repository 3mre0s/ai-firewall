# ─── Local AI Firewall — Environment Configuration ───────────────────────────
#
# Copy this file to .env and fill in your values.
# On Linux/macOS:  export $(cat .env | xargs) && ./ai-firewall
# On Windows PS:   Get-Content .env | ForEach-Object { $k,$v = $_ -split '=',2; [System.Environment]::SetEnvironmentVariable($k,$v) }
#
# ──────────────────────────────────────────────────────────────────────────────

# ─── Required ────────────────────────────────────────────────────────────────
# Your real upstream API key.
# This key is NEVER sent to the client, NEVER logged, NEVER written to disk.
# The client can send any placeholder key — the firewall replaces it here.
#
# Anthropic (Claude):
FORWARD_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_ANTHROPIC_KEY
#
# OpenAI (uncomment if using OpenAI):
# FORWARD_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
#
# Google Gemini (uncomment if using Gemini):
# FORWARD_API_KEY=AIza-REPLACE_WITH_YOUR_GEMINI_KEY
#
# Groq (uncomment if using Groq):
# FORWARD_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY
#
# Ollama or LM Studio (no auth needed — use placeholder):
# FORWARD_API_KEY=none

# ─── Upstream target ─────────────────────────────────────────────────────────
# Base URL of the real AI provider (no trailing slash).
#
# Anthropic (default):
UPSTREAM_URL=https://api.anthropic.com
#
# OpenAI:
# UPSTREAM_URL=https://api.openai.com
#
# Google Gemini:
# UPSTREAM_URL=https://generativelanguage.googleapis.com
#
# Groq:
# UPSTREAM_URL=https://api.groq.com
#
# Together AI:
# UPSTREAM_URL=https://api.together.xyz
#
# Mistral:
# UPSTREAM_URL=https://api.mistral.ai
#
# Perplexity:
# UPSTREAM_URL=https://api.perplexity.ai
#
# DeepSeek:
# UPSTREAM_URL=https://api.deepseek.com
#
# xAI (Grok):
# UPSTREAM_URL=https://api.x.ai
#
# Azure OpenAI (replace <resource> and <deployment>):
# UPSTREAM_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>
#
# Ollama (local):
# UPSTREAM_URL=http://localhost:11434
#
# LM Studio (local):
# UPSTREAM_URL=http://localhost:1234

# ─── Provider hint (optional) ────────────────────────────────────────────────
# Leave EMPTY for automatic detection from UPSTREAM_URL (recommended).
# Set only if auto-detect picks the wrong provider.
#
# Valid values: anthropic | openai | gemini | groq | together | mistral |
#               perplexity | cohere | deepseek | xai | azure | ollama |
#               lmstudio | generic
PROVIDER_HINT=

# ─── Client-side setup (not used by the firewall itself) ─────────────────────
# Set these in your AI client / SDK so it talks to the firewall instead of
# the real API. The firewall replaces the placeholder key with FORWARD_API_KEY.
#
# Anthropic SDK (Python / Node / Go):
#   ANTHROPIC_BASE_URL=http://localhost:8080
#   ANTHROPIC_API_KEY=firewall-placeholder
#
# OpenAI SDK (Python / Node / Go):
#   OPENAI_BASE_URL=http://localhost:8080
#   OPENAI_API_KEY=firewall-placeholder

# ─── Proxy settings ──────────────────────────────────────────────────────────
# Local TCP port the firewall listens on.
FIREWALL_PORT=8080

# Maximum number of label→value entries stored in memory during a session.
# Increase for very long conversations; decrease to limit RAM usage.
VAULT_SIZE_LIMIT=1000

# ─── Data categories to mask ─────────────────────────────────────────────────
# Set to false to disable a category.
MASK_PATHS=true
MASK_EMAILS=true

# ─── Logging ─────────────────────────────────────────────────────────────────
# silent — no output (production, systemd journal)
# info   — request summaries and masking events (default)
# debug  — full header dumps and pattern match details
LOG_LEVEL=info
